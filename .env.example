# Copy this file to `.env` and fill in real values before running with --storage s3
# (the pipeline runs entirely without these — defaults below keep it local-only and dry-run-safe)

# --- Storage backend -----------------------------------------------------
# "local" (default): writes to ./data/lake/<key>, mirrors the S3 key layout exactly — no
#                    credentials needed, used by --dry-run and the test suite.
# "s3": writes to a real S3 bucket via boto3 — requires the AWS_* vars below.
STORAGE_BACKEND=local
LOCAL_LAKE_ROOT=data/lake

# --- AWS / S3 (required only when STORAGE_BACKEND=s3) --------------------
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Snowflake (required only for live load_to_snowflake / build_gold) ---
# SNOWFLAKE_ACCOUNT format: <orgname>-<account_name>  (see Snowflake account identifier docs)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ECOMMERCE_DW

# --- Pipeline tuning ------------------------------------------------------
CHUNK_SIZE=10000
WEBLOG_FILE=data/raw/weblogs.csv
USERS_FILE=data/raw/users.csv
PRODUCTS_FILE=data/raw/products.csv
SQL_DIR=sql
REPORT_DIR=run_reports

# DRY_RUN=true forces NullSnowflakeLoader regardless of credentials (no live writes)
DRY_RUN=false
